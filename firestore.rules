rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isTeacherEditor() {
      return request.auth != null
        && request.auth.token.email in [
          'davisg230@gmail.com',
          'lvest@crossroadsschoolskc.org'
        ];
    }

    // Galleries collection - allow anyone to read, restrict writes to authenticated admins.
    match /galleries/{gallery} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.token.admin == true;
    }

    // Site content is public to read. Writes require Firebase auth.
    // The site signs parents in anonymously for parent actions and teachers use edit mode auth.
    match /classData/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /shoutouts/{document} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Private teacher curriculum library. Parent-facing weekly lessons will be
    // published separately after teacher review.
    match /curriculumLessons/{lessonId} {
      allow read, write: if isTeacherEditor();
    }

    // Parent action notifications. These records feed the teacher dashboard and email function.
    match /teacherActivity/{activityId} {
      allow create: if request.auth != null;
      allow read, update, delete: if request.auth != null;
    }

    // Daily visitor totals for the private teacher dashboard.
    match /siteStats/{statId} {
      allow read, write: if request.auth != null;
    }
  }
}
